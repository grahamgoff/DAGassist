@article{Pearl1995,
   abstract = {The primary aim of this paper is to show how graphical models can be used as a mathematical language for integrating statistical and subject-matter information. In particular, the paper develops a principled, nonparametric framework for causal inference, in which diagrams are queried to determine if the assumptions available are sufficient for identifying causal effects from nonexperimental data. If so the diagrams can be queried to produce mathematical expressions for causal effects in terms of observed distributions; otherwise, the diagrams can be queried to suggest additional observations or auxiliary experiments from which the desired inferences can be obtained. © 1995 Biometrika Trust.},
   author = {Judea Pearl},
   doi = {10.1093/biomet/82.4.669},
   issn = {00063444},
   issue = {4},
   journal = {Biometrika},
   keywords = {Causal inference,Graph model,Structural equations,Treatment effect},
   pages = {669-688},
   title = {Causal Diagrams for Empirical Research},
   volume = {82},
   year = {1995}
}
